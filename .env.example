# OpenClaw Gateway configuration
PYTHON_IMAGE_TAG=python:3.14-slim
OPENCLAW_GATEWAY_TOKEN=your_secure_token_here
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_ALLOW_INSECURE_AUTH=true
OPENCLAW_GATEWAY_DANGEROUSLY_DISABLE_DEVICE_AUTH=true
OPENCLAW_GATEWAY_DANGEROUSLY_ALLOW_HOST_HEADER_ORIGIN_FALLBACK=true
OPENCLAW_GATEWAY_NO_PROMPT=1
OPENCLAW_GATEWAY_NO_ONBOARD=1
OPENCLAW_OVERRIDE_CONFIG=false

# LLM Providers (at least one is required)
OPENAI_API_KEY=
OPENAI_API_BASE=
DEFAULT_MODEL_PROVIDER=litellm
OPENAI_DEFAULT_MODEL=llama_cpp/qwen3-coder-next-ud-q3
OPENAI_DEFAULT_MODEL_CONTEXT_WINDOW=262144
OPENAI_DEFAULT_MODEL_MAX_TOKENS=8192
GEMINI_API_KEY=

# Browser Control (Optional)
BROWSERLESS_BASE_URL=
BROWSERLESS_TOKEN=

# Network Configuration
# (Add custom network settings if needed)
CF_NETWORK=portainer-cloudflare-traefik_default
